    <div className="flex items-center justify-center gap-3 sm:gap-4 relative z-10 w-full">
      <BotIcon size={42} />
      <span className="text-2xl sm:text-4xl font-black text-white italic tracking-tighter drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]">Curso<sup className="text-xs bg-gradient-to-r from-blue-500 to-purple-500 px-2 py-1 rounded-full text-white ml-1.5 not-italic">AI</sup></span>
    </div>
    <div className="absolute bottom-0 right-0 w-[100px] h-[100px] bg-blue-500/30 blur-[40px] rounded-full"></div>
  </div>
);

const GDET = () => (
  <div className="relative w-full h-full flex items-center justify-center p-5 overflow-hidden rounded-2xl" style={{ background: 'linear-gradient(180deg, rgba(30,20,50,0.8) 0%, rgba(15,23,42,0.9) 100%)' }}>
    <div className="absolute top-4 left-4 w-10 h-10 bg-green-500 rounded-xl flex items-center justify-center shadow-[0_0_15px_rgba(34,197,94,0.6)] border border-white/20 transform -rotate-12"><div className="flex gap-1.5"><div className="w-2 h-2 bg-white rounded-full"></div><div className="w-2 h-2 bg-white rounded-full"></div></div></div>
    <div className="flex flex-col items-center justify-center relative z-10 mt-2">
      <span className="text-white font-black text-lg sm:text-xl leading-none drop-shadow-[0_2px_2px_rgba(0,0,0,0.8)] text-center">Certificacion</span>
